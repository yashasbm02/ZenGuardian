# ──────────────────────────────────────────────────────────────
# ZenGuardian backend environment
# Copy to ".env" and fill in real values. Never commit ".env".
# ──────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=8080

# MongoDB Atlas connection string (Vector Search requires Atlas, not local mongod)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/zenguardian?retryWrites=true&w=majority

# Auth — generate a strong secret:  openssl rand -hex 32
JWT_SECRET=replace_me_with_a_64_char_hex_secret_from_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# Chat / generation — NVIDIA (OpenAI-compatible API), running Kimi.
# Get an "nvapi-..." key from https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your_nvidia_inference_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=moonshotai/kimi-k2.6

# Embeddings — Google Gemini (separate quota from chat; keeps the 768-dim
# Atlas vector index valid). Get a key from https://aistudio.google.com
GEMINI_API_KEY=your_google_ai_studio_api_key
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# Must match the Atlas Vector Search index name you create on the "journals"
# collection (Atlas's default suggested name is "vector_index")
VECTOR_INDEX_NAME=vector_index

# Optional — enables GET /api/admin/health?key=<ADMIN_KEY> for operational monitoring.
# Generate with: openssl rand -hex 16
# If absent, the endpoint returns 404.
ADMIN_KEY=
